<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_2.xsd"
             version="3.1">
  <persistence-unit name="persistencePU">
    <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>


    <!-- Declaración manual de entidades -->
      <class>mx.puestoLidia.entity.Producto</class>
      <class>mx.puestoLidia.entity.Usuario</class>
      <class>mx.puestoLidia.entity.Cliente</class>
      <class>mx.puestoLidia.entity.Abono</class>
      <class>mx.puestoLidia.entity.Venta</class>
      <class>mx.puestoLidia.entity.ItemVenta</class>
      <class>mx.puestoLidia.entity.ItemVentaId</class>


    <properties>
      <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
      <property name="jakarta.persistence.jdbc.url" value="jdbc:mysql://localhost:3306/puestolidia?useSSL=false&amp;serverTimezone=UTC"/>
      <property name="jakarta.persistence.jdbc.user" value="root"/>
      <property name="jakarta.persistence.jdbc.password" value="root1"/>


      <property name="hibernate.show_sql" value="true"/>
      <property name="hibernate.format_sql" value="true"/>
      <property name="hibernate.hbm2ddl.auto" value="none"/>


      <property name="hibernate.hikari.minimumIdle" value="5"/>
      <property name="hibernate.hikari.maximumPoolSize" value="10"/>
      <property name="hibernate.hikari.idleTimeout" value="30000"/>
    </properties>
  </persistence-unit>
</persistence>
